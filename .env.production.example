# Supabase Configuration
# Create a Supabase project and get the Postgres connection string from Database Settings.
# Replace [YOUR_PASSWORD] and [YOUR_PROJECT_ID] accordingly. Note: you must append `?pgbouncer=true&connection_limit=1` for serverless environments if you are not using TypeORM connection pooling.
DATABASE_URL="postgresql://postgres:[YOUR_PASSWORD]@db.[YOUR_PROJECT_ID].supabase.co:5432/postgres"

# Upstash Redis Configuration
# Create a database on Upstash Console. Get the REDIS_URL from the connection details.
REDIS_URL="redis://default:[YOUR_TOKEN]@[YOUR_URL].upstash.io:6379"

# Auth Secrets
# Generate random 64-character hex strings for these in production.
# Example: `openssl rand -hex 32`
JWT_SECRET="generate-a-secure-random-string-for-jwt"
JWT_REFRESH_SECRET="generate-a-secure-random-string-for-refresh"

# Allowed Origins (CORS)
# Add your production frontend Vercel URL here.
ALLOWED_ORIGINS="https://your-tutaly-web.vercel.app"

# Application URLs
# Provide the public facing URLs for the API and WEB respectively
WEB_URL="https://your-tutaly-web.vercel.app"
API_URL="https://your-tutaly-api.up.railway.app"

# Node Environment
NODE_ENV="production"
PORT="3000"

# Mail (Nodemailer / SendGrid / Gmail SMTP)
# For SendGrid: SMTP_HOST="smtp.sendgrid.net", SMTP_PORT="465", SMTP_USER="apikey", SMTP_PASS="[YOUR_SENDGRID_API_KEY]"
SMTP_HOST="smtp.gmail.com"
SMTP_PORT="465"
SMTP_USER="your-production-email@gmail.com"
SMTP_PASS="your-app-password"

# ReCAPTCHA
RECAPTCHA_SITE_KEY="production_recaptcha_site_key"
RECAPTCHA_SECRET_KEY="production_recaptcha_secret_key"

# Flutterwave
# Get these keys from your Flutterwave Live Dashboard
FLUTTER_WAVE_PUBLIC_KEY="FLWPUBK-xxx"
FLUTTER_WAVE_SECRET_KEY="FLWSECK-xxx"
FLUTTER_WAVE_ENCRYPTION_KEY="xxx"

# AWS S3 (Supabase Storage Compatible)
# Get the S3 access keys from Supabase Storage settings
S3_ACCESS_KEY="xxx"
S3_SECRET_KEY="xxx"
S3_BUCKET="tutaly-assets-prod"
S3_REGION="us-east-1"
S3_ENDPOINT="https://[YOUR_PROJECT_ID].supabase.co/storage/v1/s3"
